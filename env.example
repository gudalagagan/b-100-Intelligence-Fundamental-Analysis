# ── Copy this file to .env and fill in your values ──────
# NEVER commit the actual .env file to Git

# Django
SECRET_KEY=your-secret-key-here-generate-a-strong-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (for ETL load + Django production)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/bluestock_dw

# Redis (for Celery background tasks)
REDIS_URL=redis://localhost:6379/0

# Power BI Gateway Token (if using Power BI Service)
PBI_GATEWAY_TOKEN=your-pbi-token-here
